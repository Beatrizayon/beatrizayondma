# Store and check out text files as LF (avoids CRLF ↔ LF noise on Windows / GitHub)
* text=auto eol=lf

*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.properties text eol=lf

# Binary — do not modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
